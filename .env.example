# Backend host the dev server proxies `/api` requests to.
# In production the app calls `/api` on the same origin, so this is dev-only.
VITE_API_PROXY_TARGET=https://api.qinvi.id

# Optional: override the API base path (defaults to `/api`).
# VITE_API_BASE_URL=/api

# Optional: fallback slug when the URL has no path segment (defaults to indah-budi).
# VITE_DEFAULT_SLUG=indah-budi
